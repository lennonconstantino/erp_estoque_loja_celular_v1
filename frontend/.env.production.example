# =============================================================================
# Template de variáveis de PRODUÇÃO do frontend (Railway).
# As variáveis VITE_* são compiladas no build (build-time), NÃO em runtime.
# Defina-as no serviço `erp-estoque-frontend` ANTES do primeiro `railway up`
# (o Railway as injeta como build args do Dockerfile). Qualquer mudança exige
# um novo deploy/build para ter efeito.
# =============================================================================

# URL pública do backend no Railway (sem barra final).
# Preencha após gerar o domínio do serviço de backend.
VITE_API_BASE_URL=https://erp-estoque-backend.up.railway.app
