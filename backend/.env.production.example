# =============================================================================
# Template de variáveis de PRODUÇÃO (Railway + Supabase).
# NÃO commite o arquivo preenchido. Copie estes valores para as variáveis do
# serviço `erp-estoque-backend` no Railway (Settings → Variables).
# =============================================================================

# ---- Aplicação ----
APP_ENV=production
# NÃO defina PORT/APP_PORT no Railway: a plataforma injeta PORT automaticamente
# e o servidor já lê PORT (fallback APP_PORT → 8080).

# ---- Banco de dados (Supabase — conexão DIRETA, porta 5432) ----
# Pegue a senha em Supabase → Project Settings → Database → Database password.
# Use a SESSION/direct connection (porta 5432), nunca o transaction pooler (6543).
# sslmode=require é obrigatório.
DATABASE_URL=postgres://postgres:SUA_SENHA_SUPABASE@db.SEU_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# ---- Autenticação JWT ----
# Gere um valor único e longo: `openssl rand -base64 64 | tr -d '\n'`.
# NUNCA reutilize o valor de dev (__INSECURE_DEV_JWT_SECRET__).
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ---- CORS ----
# Informe a URL pública do frontend no Railway (sem barra final).
# Preencha após gerar o domínio do serviço de frontend e faça redeploy do backend.
ALLOWED_ORIGINS=https://erp-estoque-frontend.up.railway.app

# ---- Integrações externas ----
CEP_API_URL=https://viacep.com.br/ws
CUPOM_FISCAL_API_URL=
NOTA_FISCAL_API_URL=

# ---- Observabilidade ----
# Tracing fica dormente sem endpoint OTLP.
OTEL_SERVICE_NAME=erp-api
OTEL_EXPORTER_OTLP_ENDPOINT=
# /metrics em produção fica FECHADO (404) enquanto METRICS_TOKEN estiver vazio.
# Para habilitar o scraping autenticado (ex.: Grafana Alloy → Grafana Cloud),
# gere um token — `openssl rand -hex 32` — e informe o MESMO valor ao Alloy
# (ERP_METRICS_TOKEN). Ver observability/alloy e docs/architecture/observability.md.
METRICS_TOKEN=
