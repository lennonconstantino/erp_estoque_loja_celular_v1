# ---- Aplicação ----
APP_ENV=development
APP_PORT=8080

# ---- Banco de dados (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=erp
DB_PASSWORD=
DB_NAME=erp_estoque
DB_SSLMODE=disable
# string de conexão usada pelos migrations e pela aplicação (obrigatória).
# IMPORTANTE: escreva a URL literal — o Docker Compose NÃO expande ${VAR} dentro
# de valores de .env. Ex.: postgres://erp:SUA_SENHA@localhost:5432/erp_estoque?sslmode=disable
DATABASE_URL=postgres://erp:@localhost:5432/erp_estoque?sslmode=disable

# ---- Autenticação JWT ----
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ---- CORS ----
# Origens permitidas, separadas por vírgula.
# Dev com Vite (make fe-dev):  http://localhost:5173
# Dev com Docker (make up):    http://localhost,http://localhost:5173
# Produção: informe a URL do frontend (ex.: https://erp-frontend.railway.app)
ALLOWED_ORIGINS=http://localhost:5173

# ---- Integrações externas ----
CEP_API_URL=https://viacep.com.br/ws
CUPOM_FISCAL_API_URL=
NOTA_FISCAL_API_URL=

# ---- Observabilidade (OpenTelemetry) ----
# Métricas ficam expostas em /metrics (raspadas pelo Prometheus/Alloy).
OTEL_SERVICE_NAME=erp-api
# Protege o /metrics. Vazio em dev libera o scraping local; em PRODUÇÃO, vazio
# FECHA o endpoint (404) — defina um token forte e informe o mesmo valor ao
# scraper (ex.: ERP_METRICS_TOKEN do Grafana Alloy). Ver observability/alloy.
METRICS_TOKEN=
# Tracing fica DORMENTE enquanto vazio. Preencher com o endpoint de um OTel
# Collector liga a exportação de spans (ex.: http://localhost:4318 em dev, ou
# http://otel-collector:4318 em docker). Ver docs/architecture/observability.md.
OTEL_EXPORTER_OTLP_ENDPOINT=
