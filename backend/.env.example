# ---- Aplicação ----
APP_ENV=development
APP_PORT=8080

# ---- Banco de dados (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=erp
DB_PASSWORD=erp_secret
DB_NAME=erp_estoque
DB_SSLMODE=disable
# string de conexão usada pelos migrations e pela aplicação
DATABASE_URL=postgres://erp:erp_secret@localhost:5432/erp_estoque?sslmode=disable

# ---- Autenticação JWT ----
JWT_SECRET=troque-este-segredo-em-producao
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ---- Integrações externas ----
CEP_API_URL=https://viacep.com.br/ws
CUPOM_FISCAL_API_URL=
NOTA_FISCAL_API_URL=
