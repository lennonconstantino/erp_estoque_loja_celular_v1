# ---- Aplicação ----
APP_ENV=development
APP_PORT=8080

# ---- Banco de dados (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=erp
DB_PASSWORD=
DB_NAME=erp_estoque
DB_SSLMODE=disable
# string de conexão usada pelos migrations e pela aplicação (obrigatória) 
# exemplo: postgres://erp:${DB_PASSWORD}@localhost:5432/erp_estoque?sslmode=disable
DATABASE_URL=

# ---- Autenticação JWT ----
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ---- CORS ----
# Origens permitidas, separadas por vírgula. Padrão em dev: http://localhost:5173
# Em produção: informe a URL do frontend (ex.: https://erp-frontend.railway.app)
ALLOWED_ORIGINS=http://localhost:5173

# ---- Integrações externas ----
CEP_API_URL=https://viacep.com.br/ws
CUPOM_FISCAL_API_URL=
NOTA_FISCAL_API_URL=

# ---- Observabilidade (OpenTelemetry) ----
# Métricas ficam sempre expostas em /metrics (raspadas pelo Prometheus).
OTEL_SERVICE_NAME=erp-api
# Tracing fica DORMENTE enquanto vazio. Preencher com o endpoint de um OTel
# Collector liga a exportação de spans (ex.: http://localhost:4318 em dev, ou
# http://otel-collector:4318 em docker). Ver docs/architecture/observability.md.
OTEL_EXPORTER_OTLP_ENDPOINT=
